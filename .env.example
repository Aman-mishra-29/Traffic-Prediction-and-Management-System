# -------------------------------
# Model Configuration
# -------------------------------

# Path to trained YOLO model
MODEL_PATH=models/best.pt

# Model version (for future versioning support)
MODEL_VERSION=v1

# Confidence threshold for detection
CONFIDENCE_THRESHOLD=0.4


# -------------------------------
# Video Source Configuration
# -------------------------------

# Path to video file OR camera index (0 for webcam)
VIDEO_PATH=sample_video.mp4

# Frames per second of video
FPS=30


# -------------------------------
# Traffic Analytics Configuration
# -------------------------------

# Pixel-to-meter conversion factor
PIXELS_PER_METER=8

# Speed limit in km/h
SPEED_LIMIT=60


# -------------------------------
# API Configuration
# -------------------------------

# API Host
HOST=127.0.0.1

# API Port
PORT=8000

# Debug mode (True / False)
DEBUG=True


# -------------------------------
# Security Configuration (Future Use)
# -------------------------------

# API Key for protected routes
API_KEY=your_api_key_here


# -------------------------------
# Logging Configuration
# -------------------------------

# Log level (INFO, DEBUG, WARNING, ERROR)
LOG_LEVEL=INFO
